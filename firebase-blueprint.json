{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information collected from the online consulting form.",
      "type": "object",
      "properties": {
        "nome": {
          "type": "string",
          "description": "Full name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead."
        },
        "telefone": {
          "type": "string",
          "description": "Phone number of the lead."
        },
        "profissao": {
          "type": "string",
          "description": "Profession of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the lead was created."
        }
      },
      "required": ["nome", "email", "telefone", "profissao", "createdAt"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads from the online consulting form."
    },
    "leads_presencial/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads from the presencial consulting form."
    }
  }
}
